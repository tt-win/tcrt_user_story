# Docker runtime example for an app container with external dependencies.
# The databases are expected to be provided outside this compose stack.
# This is the docker-focused subset; see .env.example for the complete,
# annotated list of every configurable variable.

# Runtime detection / config path
APP_ENV=docker
RUNNING_IN_DOCKER=1
# APP_CONFIG_PATH=/app/config.yaml

# Web app bind + public URL
DEBUG=false
HOST=0.0.0.0
PORT=9999
APP_PUBLISHED_PORT=9999
PUBLIC_BASE_URL=https://tcrt.example.com
# Legacy alias; prefer PUBLIC_BASE_URL
# APP_BASE_URL=https://tcrt.example.com

# Main / audit / USM databases (external services)
DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_main
SYNC_DATABASE_URL=postgresql+psycopg://tcrt:replace-me@db-host:5432/tcrt_main
AUDIT_DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_audit
USM_DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_usm
# Keep disabled unless you intentionally allow sync DB access in runtime.
# ALLOW_SYNC_DB_RUNTIME=0

# Boot-time upgrade backup & rollback (see docs/database-cutover-readiness.md).
# Directory backed by the named volume `tcrt-db-backups` in docker-compose.app.yml.
# Required for both the rollback policy and the failure-marker loop guard to work
# across container recreation — an ephemeral dir silently disables both.
BOOTSTRAP_BACKUP_DIR=/app/db_backups
# required: fail the boot if a pre-upgrade backup can't be created (missing dump
# client, unwritable dir, etc). best-effort: warn and continue. off: never backup
# (equivalent to --no-backup).
BOOTSTRAP_BACKUP_MODE=required
# How many of the most recent backups to keep per database (main/audit/usm each
# have their own subdirectory and count).
BOOTSTRAP_BACKUP_RETENTION=5
# abort: stop the container on a failed upgrade (old behavior). rollback: restore
# every database this boot touched back to its pre-upgrade state and stop the
# container — the OLD image can then be redeployed immediately. Restoring a
# PostgreSQL target this way requires the app's DB user to own the `public`
# schema (DROP/CREATE SCHEMA); restoring MySQL requires DROP/CREATE TABLE rights.
BOOTSTRAP_ON_FAILURE=abort
# After this many consecutive failed upgrade attempts against the same Alembic
# head, boot refuses to try again (protects against a restart-policy loop
# repeatedly backing up / failing / rolling back). Clear with:
#   docker compose -f docker-compose.app.yml run --rm app python3 database_init.py --clear-failure-markers
BOOTSTRAP_MAX_UPGRADE_ATTEMPTS=3

# Container startup
SKIP_DATABASE_BOOTSTRAP=0
# The entrypoint retries `database_init.py` up to this many times (3s apart) before
# giving up, to ride out the external DB service still starting up (this compose
# stack doesn't include one — see the top of this file). Not a substitute for
# BOOTSTRAP_MAX_UPGRADE_ATTEMPTS: that one bounds retries of a genuinely failing
# migration across container recreations; this one only covers the connection race
# within a single startup attempt.
BOOTSTRAP_WAIT_ATTEMPTS=10
BOOTSTRAP_WAIT_SECONDS=3
UVICORN_LOG_LEVEL=info
UVICORN_PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=*
# uvicorn workers. Leave unset to auto-pick from DATABASE_URL:
#   SQLite → 1 ; MySQL / PostgreSQL → 5
# Explicit value always wins. Safe to scale (>1): background scheduler/automation
# ticker uses DB advisory-lock leader election; login challenges and permission
# cache invalidation are shared via the DB. Residual caveat: a permission change
# on one worker can take up to ~30s to become visible on others (PermissionCache
# TTL). Size container CPU/memory for the worker count you choose.
# WEB_CONCURRENCY=5

# Storage mounted from the host into the container
ATTACHMENTS_ROOT_DIR=/Users/name/tcrt_files/attachments
REPORTS_ROOT_DIR=/Users/name/tcrt_files/reports

# RSA signing-key directory INSIDE the container (backed by the named volume `tcrt-keys`
# in docker-compose.app.yml). Persisting this is REQUIRED: if the directory is ephemeral,
# the keypair is regenerated on every container rebuild and all previously RSA-encrypted
# login payloads become undecryptable. Leave as /app/keys unless you mount elsewhere.
RSA_KEY_DIR=/app/keys

# Auth
ENABLE_AUTH=true
# REQUIRED when ENABLE_AUTH=true — the app fails fast at startup if this is empty.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me
JWT_EXPIRE_DAYS=7
PASSWORD_RESET_EXPIRE_HOURS=24
SESSION_CLEANUP_DAYS=30

# Audit
ENABLE_AUDIT=true
AUDIT_BATCH_SIZE=100
AUDIT_CLEANUP_DAYS=365
AUDIT_MAX_DETAIL_SIZE=10240
AUDIT_DEBUG_SQL=false

# USM
USM_DEBUG_SQL=false

# Lark
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DRY_RUN=false

# Jira
JIRA_SERVER_URL=https://jira.example.com/jira
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_CA_CERT_PATH=

# LLM / AI
OPENROUTER_API_KEY=

# Automation Hub — AES-256-GCM key (base64-encoded 32 bytes). Generate with:
#   python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# Required once team_automation_providers has any row; bootstrap blocks startup otherwise.
AUTOMATION_PROVIDER_ENCRYPTION_KEY=

# Optional bootstrap values consumed by database_init.py
# BOOTSTRAP_SUPER_ADMIN_USERNAME=admin
# BOOTSTRAP_SUPER_ADMIN_FULL_NAME=TCRT Admin
# BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=replace-me

# Nested AI helper tuning still lives in config.yaml.
