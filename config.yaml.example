app:
  database_url: sqlite:///./test_case_repo.db
  debug: false
  host: 0.0.0.0
  port: 9999
  public_base_url: ''  # 對外可達網址；Docker/反向代理部署建議明確設定或改用 PUBLIC_BASE_URL
jira:
  api_token: 'YOUR_JIRA_API_TOKEN'
  server_url: 'https://your-domain.atlassian.net'
  username: 'your-username'
  ca_cert_path: ''
lark:
  app_id: 'YOUR_LARK_APP_ID'
  app_secret: 'YOUR_LARK_APP_SECRET'
openrouter:
  api_key: 'YOUR_OPENROUTER_API_KEY'
ai:
  qa_ai_helper:
    enable: true
    prompt_contract_version: 'qa-ai-helper.prompt.v1'
    payload_contract_version: 'qa-ai-helper.payload.v1'
    min_steps: 3
    min_preconditions: 1
    max_repair_rounds: 1
    generation_budget_row_limit: 120  # 0 = 無上限
    generation_budget_prompt_tokens: 12000  # 0 = 無上限
    generation_budget_output_tokens: 12000  # 0 = 無上限
    max_concurrent_llm_calls: 5  # seed / testcase 生成最大併發 LLM worker 數
    models:
      # 可直接填 model id，或改成 '${QA_AI_HELPER_MODEL_SEED}'
      # temperature 可改成 '${QA_AI_HELPER_MODEL_SEED_TEMPERATURE}'
      seed:
        model: 'google/gemini-3-flash-preview'
        temperature: 0.1
      # 可直接填 model id，或改成 '${QA_AI_HELPER_MODEL_SEED_REFINE}'
      # 若保留 null，runtime 會 fallback 到 seed
      seed_refine:
        model: 'google/gemini-3-flash-preview'
        temperature: 0.0
      # 可直接填 model id，或改成 '${QA_AI_HELPER_MODEL_TESTCASE}'
      # temperature 可改成 '${QA_AI_HELPER_MODEL_TESTCASE_TEMPERATURE}'
      testcase:
        model: 'google/gemini-3-flash-preview'
        temperature: 0.0
      # --- Council Inspection 模型設定 ---
      # Extraction Phase: 三個不同模型各自負責不同角色方向
      inspection_extraction_a:
        model: 'openai/gpt-5.4-mini'
        temperature: 0.1
      inspection_extraction_b:
        model: 'google/gemini-3-flash-preview'
        temperature: 0.1
      inspection_extraction_c:
        model: 'x-ai/grok-4.20'
        temperature: 0.1
      # Consolidation Phase: 高階模型統合結果
      inspection_consolidation:
        model: 'openai/gpt-5.3-chat'
        temperature: 0.1
    inspection:
      max_scenarios_warning: 5  # 超過此值時前端提醒使用者 inspection 可能耗時較長
      roles:
        - label: 'A'
          role_name: 'Happy Path + Permission'
          role_focus: '你專注於 Happy Path（正常流程驗證）與基本 Permission（權限控制）。確保主要正常使用情境都有對應的驗證項目，以及各角色的存取權限控制正確。'
        - label: 'B'
          role_name: 'Edge Cases + Performance'
          role_focus: '你專注於 Edge Cases（邊界與異常輸入）與 Performance/Concurrency（效能與併發）。找出邊界值、空值、超長輸入、特殊字元等情境，以及併發操作、大量資料等效能相關的驗證項目。'
        - label: 'C'
          role_name: 'Error Handling + Abuse'
          role_focus: '你專注於 Error Handling（錯誤處理）、進階 Permission 與 Abuse（濫用防護）。確保各種錯誤情境的處理正確，以及系統能防範惡意操作與權限繞過。'
qdrant:
  url: 'http://localhost:6333'
  api_key: ''
  timeout: 30
  prefer_grpc: false
  pool_size: 32
  max_concurrent_requests: 32
  max_retries: 3
  retry_backoff_seconds: 0.5
  retry_backoff_max_seconds: 5.0
  check_compatibility: true
  collection_jira_referances: 'jira_references'
  collection_test_cases: 'test_cases'
  collection_usm_nodes: 'usm_nodes'
  weights:
    test_cases: 0.7
    usm_nodes: 0.3
  limit:
    jira_referances: 20
    test_cases: 14
    usm_nodes: 6
auth:
  enable_auth: true
  jwt_secret_key: '${JWT_SECRET_KEY}'  # 必須由環境變數提供
  jwt_expire_days: 7
  password_reset_expire_hours: 24
  session_cleanup_days: 30
audit:
  enabled: true
  database_url: 'sqlite:///./audit.db'
  batch_size: 100
  cleanup_days: 365
  max_detail_size: 10240
  excluded_fields: ['password', 'token', 'secret', 'key']
  debug_sql: false
usm:
  database_url: 'sqlite:///./userstorymap.db'
  debug_sql: false
attachments:
  root_dir: ''  # 留空使用專案內 attachments 目錄
reports:
  root_dir: ''  # 留空使用專案內 generated_report 目錄
