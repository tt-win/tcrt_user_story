# config/<env>.yaml.example  — generated by tcrt-automation-pomify.
#
# PLACEHOLDERS ONLY. The real per-environment values live in TCRT, never in git:
#   * Shared params      → Automation Hub → Settings → Environments
#   * Per-script override → Scripts tab → Script view → "Configure variables"
#
# This .example file documents which keys exist (one per name in TCRT_VARS) so
# contributors can see the shape. Copy it to config/<env>.yaml LOCALLY only if
# you must run outside TCRT — that real file is .gitignored and must NOT be
# committed. At run time TCRT injects values via TCRT_ENV_BUNDLE → tcrt-env.json;
# you do not need a config file at all when running through a Test Run Set.
#
# One key per TCRT_VARS name. Values are placeholders — no real URLs or secrets.

BASE_URL: "<https://sit.example.invalid>"
API_TOKEN: "<set-in-TCRT-or-export-locally>"   # secret — never commit a real token
