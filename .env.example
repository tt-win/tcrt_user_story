# =============================================================================
# TCRT 環境變數總覽範例檔（.env.example）
# =============================================================================
# 本檔列出 TCRT 所有可透過環境變數設定的項目與用途。
# 使用方式：
#   - 本機開發：cp .env.example .env，按需修改（app 啟動時由 load_dotenv() 載入）。
#   - Docker 部署：cp .env.docker.example .env.docker（該檔為容器情境的精簡子集，
#     並由 docker-compose.app.yml 的 env_file 載入；本檔為完整參考）。
# 優先序：環境變數 > config.yaml > 程式內建預設值。
# 巢狀的 AI helper 進階調校（models 以外的欄位）仍在 config.yaml，見 config.yaml.example。
# 安全提醒：真實的 .env / .env.docker 已被 gitignore，切勿提交任何密鑰。

# -----------------------------------------------------------------------------
# 執行環境偵測
# -----------------------------------------------------------------------------
# 標記在容器內執行（APP_ENV=docker/container 或 RUNNING_IN_DOCKER=1 皆可）。
# 觸發容器專屬檢查：localhost URL 警告、SQLite 儲存風險 fail-fast 等。
# APP_ENV=docker
# RUNNING_IN_DOCKER=1

# config.yaml 的路徑（預設專案根目錄的 config.yaml；容器內預設 /app/config.yaml）。
# APP_CONFIG_PATH=/app/config.yaml

# 【docker-compose 專用】把 host 上哪個檔案掛載成容器內的 /app/config.yaml
# （預設 ./config.yaml；只影響 docker-compose.app.yml 的 volume 插值）。
# APP_CONFIG_FILE=./config.yaml

# -----------------------------------------------------------------------------
# Web 服務
# -----------------------------------------------------------------------------
# 除錯模式（true 會輸出較多日誌；正式環境務必 false）。
DEBUG=false
# uvicorn 綁定位址與埠。
HOST=0.0.0.0
PORT=9999
# 【docker-compose 專用】容器對外發布的 host 埠（映射到容器內 9999）。
# APP_PUBLISHED_PORT=9999
# 對外基礎網址：產生通知連結、報告連結等對外 URL 時使用。
# 反向代理/容器部署務必設定，否則連結會落到 localhost。
PUBLIC_BASE_URL=https://tcrt.example.com
# PUBLIC_BASE_URL 的舊名別稱（已棄用，優先用 PUBLIC_BASE_URL）。
# APP_BASE_URL=https://tcrt.example.com

# uvicorn 日誌等級（docker entrypoint 使用）。
UVICORN_LOG_LEVEL=info
# 位於反向代理後方時啟用（信任 X-Forwarded-* 標頭）。
UVICORN_PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=*
# uvicorn worker 數。未設定時依 DATABASE_URL 自動選擇：SQLite → 1，MySQL/PostgreSQL → 5。
# 明確設定時以你的值為準。>1 安全：背景服務有 leader 選舉、登入 challenge 與權限快取
# 已跨 worker 共用（殘留限制：權限變更跨 worker 最多 ~30 秒延遲可見）。
# WEB_CONCURRENCY=5

# Super Admin 系統 log viewer（/system-logs）。所有容量均為 per-worker，
# 總記憶體需乘上 WEB_CONCURRENCY；範圍外或非法值自動回落預設。
# 詳見 docs/system-log-viewer.md。
# LOG_VIEWER_BUFFER_SIZE=2000                # in-memory buffer 筆數（1–20000）
# LOG_VIEWER_MAX_STREAMS=3                   # 同時 SSE 串流數（1–10）
# LOG_VIEWER_MAX_MESSAGE_CHARS=4096          # 單條訊息字元上限（1–65536）
# LOG_VIEWER_SUBSCRIBER_QUEUE_SIZE=1000      # 每串流 pending 筆數（1–10000）
# LOG_VIEWER_KEEPALIVE_SECONDS=15            # SSE keep-alive 間隔（5–60）
# LOG_VIEWER_STREAM_MAX_LIFETIME_SECONDS=900 # 串流最大生命週期（60–3600）

# -----------------------------------------------------------------------------
# 資料庫（main / audit / usm 三庫）
# -----------------------------------------------------------------------------
# 支援 SQLite / MySQL 8 / PostgreSQL 16；async driver 會自動正規化
# （mysql→asyncmy、postgresql→asyncpg、sqlite→aiosqlite）。
DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_main
# 同步連線字串（migration / bootstrap 等明確場景使用；未設時由 DATABASE_URL 推導）。
SYNC_DATABASE_URL=postgresql+psycopg://tcrt:replace-me@db-host:5432/tcrt_main
AUDIT_DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_audit
USM_DATABASE_URL=postgresql+asyncpg://tcrt:replace-me@db-host:5432/tcrt_usm
# 允許 web runtime 使用同步 DB engine（僅除錯用；正式環境保持關閉）。
# ALLOW_SYNC_DB_RUNTIME=0
# 容器內使用 SQLite 時必須設 1 才能開機：明確承認「未掛 volume 時容器重建會
# 靜默遺失所有資料」的風險（建議正式環境改用 MySQL/PostgreSQL）。
# SQLITE_CONTAINER_STORAGE_ACK=1

# -----------------------------------------------------------------------------
# 開機 bootstrap 與升版備份/回退（詳見 docs/database-cutover-readiness.md）
# -----------------------------------------------------------------------------
# 設 1 完全跳過 database_init.py（維運除錯用）。
SKIP_DATABASE_BOOTSTRAP=0
# 【docker entrypoint 專用】外部 DB 尚未就緒時，database_init.py 的重試次數與間隔秒數
# （涵蓋單次啟動內的連線競態；與 BOOTSTRAP_MAX_UPGRADE_ATTEMPTS 分工不同）。
BOOTSTRAP_WAIT_ATTEMPTS=10
BOOTSTRAP_WAIT_SECONDS=3
# 升版前備份與連續失敗 marker 的存放目錄（容器部署由 named volume tcrt-db-backups
# 持久化；不持久化則失敗計數每次重建歸零、防迴圈保護失效）。
BOOTSTRAP_BACKUP_DIR=/app/db_backups
# required：備份失敗（缺 mysqldump/pg_dump、目錄不可寫等）即中止啟動。
# best-effort：記警告後繼續。off：不備份（等同 --no-backup）。
BOOTSTRAP_BACKUP_MODE=required
# 每個資料庫（main/audit/usm 各自）保留的最近備份數。
BOOTSTRAP_BACKUP_RETENTION=5
# abort：升版失敗即中止。rollback：把本次啟動已升版的所有資料庫還原到升版前狀態後
# 中止（換回舊版 image 即可立即開機）。PostgreSQL 還原需帳號擁有 public schema
# （DROP/CREATE SCHEMA）；MySQL 需 DROP/CREATE TABLE 權限。
BOOTSTRAP_ON_FAILURE=abort
# 同一 Alembic head 連續升版失敗達此次數即拒絕再試（防 restart-loop 反覆備份/回退）。
# 解鎖：python3 database_init.py --clear-failure-markers
BOOTSTRAP_MAX_UPGRADE_ATTEMPTS=3

# 首次 bootstrap 時自動建立的超級管理員（僅在 users 表為空時生效）。
# BOOTSTRAP_SUPER_ADMIN_USERNAME=admin
# BOOTSTRAP_SUPER_ADMIN_FULL_NAME=TCRT Admin
# BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_SUPER_ADMIN_PASSWORD=replace-me

# -----------------------------------------------------------------------------
# 認證與密碼
# -----------------------------------------------------------------------------
ENABLE_AUTH=true
# ENABLE_AUTH=true 時必填，留空會在啟動時 fail fast。
# 產生方式：python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me
# JWT 有效天數。
JWT_EXPIRE_DAYS=7
# 密碼重設連結有效小時數。
PASSWORD_RESET_EXPIRE_HOURS=24
# 過期 session 清理保留天數。
SESSION_CLEANUP_DAYS=30
# RSA 登入密碼加密金鑰對的目錄（預設專案內 keys/；容器內 /app/keys，由 named volume
# tcrt-keys 持久化——不持久化則每次重建重生金鑰，舊加密 payload 全部無法解密）。
# RSA_KEY_DIR=/app/keys

# -----------------------------------------------------------------------------
# 稽核（audit）
# -----------------------------------------------------------------------------
ENABLE_AUDIT=true
# 批次寫入大小與清理保留天數。
AUDIT_BATCH_SIZE=100
AUDIT_CLEANUP_DAYS=365
# 單筆 audit detail 最大位元組數（超過會截斷）。
AUDIT_MAX_DETAIL_SIZE=10240
# 輸出 audit SQL 除錯日誌。
AUDIT_DEBUG_SQL=false

# -----------------------------------------------------------------------------
# User Story Map
# -----------------------------------------------------------------------------
# 輸出 USM SQL 除錯日誌。
USM_DEBUG_SQL=false

# -----------------------------------------------------------------------------
# 檔案儲存
# -----------------------------------------------------------------------------
# 附件與報告的根目錄（留空用專案內 attachments/、generated_report/）。
# 容器部署會以「同路徑」bind mount 進容器以保留 DB 內 absolute_path 相容性，
# 且目錄必須對容器內 uid 10001 可寫。
# ATTACHMENTS_ROOT_DIR=/srv/tcrt/attachments
# REPORTS_ROOT_DIR=/srv/tcrt/reports

# -----------------------------------------------------------------------------
# Lark 整合
# -----------------------------------------------------------------------------
LARK_APP_ID=
LARK_APP_SECRET=
# true 時僅模擬發送通知（開發/測試環境建議開啟）。
LARK_DRY_RUN=false

# -----------------------------------------------------------------------------
# Jira 整合
# -----------------------------------------------------------------------------
JIRA_SERVER_URL=https://jira.example.com/jira
JIRA_USERNAME=
JIRA_API_TOKEN=
# 自簽/內部 CA 憑證路徑（留空用系統預設 CA）。
JIRA_CA_CERT_PATH=

# -----------------------------------------------------------------------------
# LLM / QA AI Helper
# -----------------------------------------------------------------------------
# OpenRouter API 金鑰（QA AI Helper 等 LLM 功能必需）。
OPENROUTER_API_KEY=
# QA AI Helper 各階段模型與溫度覆蓋（未設則用 config.yaml / 內建預設）。
# 可用階段：SEED / SEED_REFINE / TESTCASE / INSPECTION_EXTRACTION_A /
# INSPECTION_EXTRACTION_B / INSPECTION_EXTRACTION_C / INSPECTION_CONSOLIDATION，
# 變數格式：QA_AI_HELPER_MODEL_<階段> 與 QA_AI_HELPER_MODEL_<階段>_TEMPERATURE。
# QA_AI_HELPER_MODEL_SEED=google/gemini-3-flash-preview
# QA_AI_HELPER_MODEL_SEED_TEMPERATURE=0.1
# QA_AI_HELPER_MODEL_TESTCASE=google/gemini-3-flash-preview
# QA_AI_HELPER_MODEL_TESTCASE_TEMPERATURE=0.0
# 三模型合議（inspection extraction A/B/C，各帶不同 role focus）＋整合審核
# （consolidation）；下列為程式內建預設值。
# QA_AI_HELPER_MODEL_INSPECTION_EXTRACTION_A=openai/gpt-5.4-mini
# QA_AI_HELPER_MODEL_INSPECTION_EXTRACTION_B=google/gemini-3-flash-preview
# QA_AI_HELPER_MODEL_INSPECTION_EXTRACTION_C=x-ai/grok-4.20
# QA_AI_HELPER_MODEL_INSPECTION_CONSOLIDATION=openai/gpt-5.3-chat
# LLM 併發呼叫上限。
# QA_AI_HELPER_MAX_CONCURRENT_LLM_CALLS=5

# -----------------------------------------------------------------------------
# Automation Hub
# -----------------------------------------------------------------------------
# Provider 憑證的 AES-256-GCM 加密金鑰（base64 的 32 bytes）。
# 一旦 team_automation_providers 有資料即為必填，缺少會擋下開機。
# 產生方式：python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
AUTOMATION_PROVIDER_ENCRYPTION_KEY=
# Allure 報告伺服器（供 Suite CI 報告連結）。
# ALLURE_BASE_URL=
# ALLURE_API_TOKEN=
# Allure project id 命名模板（預設 tcrt-team-{team_slug}-{suite_slug}-{suite_id}；
# 務必保持 per-suite 唯一，否則報告歷史會互相清除）。
# ALLURE_PROJECT_ID_TEMPLATE=tcrt-team-{team_slug}-{suite_slug}-{suite_id}

# -----------------------------------------------------------------------------
# 開發 / 測試專用（正式環境不需要）
# -----------------------------------------------------------------------------
# 指向 disposable 的真實 DB server 時，跑對應的整合測試（未設則自動 skip）。
# TCRT_TEST_MYSQL_URL=mysql+pymysql://tcrt:tcrt@127.0.0.1:33060/tcrt_main
# TCRT_TEST_POSTGRES_URL=postgresql+psycopg://tcrt:tcrt@127.0.0.1:5433/tcrt_main
